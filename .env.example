# GCP Configuration
GCP_PROJECT_ID=your_project_id_here
GCP_LOCATION=us-central1
GCP_SERVICE_ACCOUNT_KEY=your_service_account_key_json_here

# Artifact Registry
ARTIFACT_REGISTRY_NAME=airflow-docker-image
REPO_FORMAT=DOCKER

# Docker Image Names
DOCKER_IMAGE_NAME=data-pipeline
DOCKER_IMAGE_TAG=latest

# VM Configuration
VM_NAME=airflow-server
VM_ZONE=us-central1-a
REMOTE_USER=ubuntu

# Database
MYSQL_HOST=your_cloud_sql_ip_here
MYSQL_USER=your_db_user_here
MYSQL_PASSWORD=your_db_password_here
MYSQL_DATABASE=your_database_name_here

# Airflow
AIRFLOW_DATABASE_PASSWORD=your_airflow_db_password_here

# API
API_TOKEN=your_api_token_here

# Email alerts
SMTP_EMAIL=your_email_here
SMTP_PASSWORD=your_smtp_password_here

# Model configuration
MODEL_NAME=lstm_model.keras
TRAINED_MODEL_BUCKET_URI=gs://your_trained_model_bucket
MODEL_TRAINING_BUCKET_URI=gs://your_training_bucket